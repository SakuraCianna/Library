{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "个人知识库",
  "version": "0.1.0",
  "identifier": "com.sakura.personal-knowledge-base",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "个人知识库",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../sidecars/ocr/check_ocr_environment.py": "sidecars/ocr/check_ocr_environment.py",
      "../../sidecars/ocr/ocr_sidecar.py": "sidecars/ocr/ocr_sidecar.py",
      "../../sidecars/ocr/requirements.txt": "sidecars/ocr/requirements.txt",
      "../../sidecars/parser/parser_sidecar.py": "sidecars/parser/parser_sidecar.py",
      "../../sidecars/parser/requirements.txt": "sidecars/parser/requirements.txt"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
